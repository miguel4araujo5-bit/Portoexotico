{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portoexotico",
  "compatibility_date": "2026-03-31",
  "pages_build_output_dir": "dist",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "portoexotico-db",
      "database_id": "COLOCA_AQUI_O_DATABASE_ID"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "ADMIN_RATE_LIMIT_KV",
      "id": "COLOCA_AQUI_O_KV_ID"
    }
  ]
}
